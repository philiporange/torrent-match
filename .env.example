# TMDB API Key (required for IMDB ID recovery)
# Get your API key from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# LLM API Key (optional, for LLM fallback parser)
# Can be OpenRouter API key or OpenAI API key
LLM_API_KEY=your_llm_api_key_here

# LLM API Endpoint (optional, defaults to OpenAI)
# For OpenRouter: https://openrouter.ai/api/v1
# For OpenAI: https://api.openai.com/v1
LLM_API_ENDPOINT=https://openrouter.ai/api/v1

# LLM Model (optional, overrides default model)
# OpenRouter examples: google/gemini-2.0-flash-exp, anthropic/claude-3-haiku:beta
# OpenAI examples: gpt-3.5-turbo, gpt-4
LLM_MODEL=google/gemini-2.5-flash-latest

# Cache database path (redislite database file)
# This file will be created automatically
CACHE_DB_PATH=/tmp/torrent_interpret.db
